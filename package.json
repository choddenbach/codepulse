{
  "name": "codepulse",
  "version": "0.1.0",
  "description": "Instant codebase health scores — complexity, dependencies, test coverage, documentation, and security in one scan.",
  "bin": {
    "codepulse": "./dist/codepulse.js"
  },
  "module": "src/index.ts",
  "main": "./index.ts",
  "type": "module",
  "files": [
    "src",
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir dist --target node --entry-naming codepulse.js && printf '#!/usr/bin/env node\n' | cat - dist/codepulse.js > dist/tmp && mv dist/tmp dist/codepulse.js && chmod +x dist/codepulse.js",
    "prepublishOnly": "bun run build",
    "scan": "bun ./bin/codepulse scan",
    "test": "bun test"
  },
  "keywords": [
    "code-quality",
    "codebase-health",
    "static-analysis",
    "complexity",
    "security",
    "cli",
    "developer-tools",
    "metrics"
  ],
  "author": "CodePulse Authors",
  "license": "MIT",
  "homepage": "https://github.com/choddenbach/codepulse",
  "repository": {
    "type": "git",
    "url": "https://github.com/choddenbach/codepulse.git"
  },
  "bugs": {
    "url": "https://github.com/choddenbach/codepulse/issues"
  },
  "dependencies": {
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0",
    "@babel/types": "^7.27.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.7",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
